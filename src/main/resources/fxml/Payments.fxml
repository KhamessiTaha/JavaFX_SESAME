<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.tahakhamessi.controller.PaymentsController" spacing="20" style="-fx-padding: 20">
    <Label text="Payment Management" styleClass="label-header"/>

    <VBox spacing="10" styleClass="card">
        <Label text="Payment Details" styleClass="label-subheader"/>
        <GridPane hgap="15" vgap="10">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100" />
            </columnConstraints>

            <ComboBox fx:id="reservationCombo" promptText="Select Reservation" GridPane.columnIndex="0" GridPane.rowIndex="0" maxWidth="Infinity" GridPane.columnSpan="2"/>

            <TextField fx:id="montantTotalField" promptText="Total Amount (TND)" GridPane.columnIndex="0" GridPane.rowIndex="1" maxWidth="Infinity" onKeyReleased="#handleCalculateReste"/>
            <TextField fx:id="montantPayeField" promptText="Amount Paid (TND)" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity" onKeyReleased="#handleCalculateReste"/>
            <TextField fx:id="resteAPayerField" promptText="Balance Due (TND)" GridPane.columnIndex="2" GridPane.rowIndex="1" maxWidth="Infinity" editable="false" style="-fx-background-color: #f8f9fa;"/>

            <ComboBox fx:id="modePaiementCombo" promptText="Payment Mode" GridPane.columnIndex="0" GridPane.rowIndex="2" maxWidth="Infinity"/>
            <ComboBox fx:id="statutPaiementCombo" promptText="Payment Status" GridPane.columnIndex="1" GridPane.rowIndex="2" maxWidth="Infinity"/>
        </GridPane>

        <HBox spacing="10">
            <Button text="Add Payment" onAction="#handleAddPaiement" styleClass="button-success"/>
            <Button text="Update Selected" onAction="#handleUpdatePaiement" styleClass="button-primary"/>
        </HBox>
    </VBox>

    <Label fx:id="errorLabel" style="-fx-text-fill: #F44336;"/>
    <Label fx:id="successLabel" style="-fx-text-fill: #4CAF50;"/>

    <TableView fx:id="paiementTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol" text="ID" prefWidth="40"/>
            <TableColumn fx:id="resIdCol" text="Res ID" prefWidth="60"/>
            <TableColumn fx:id="montantTotalCol" text="Total (TND)" prefWidth="120"/>
            <TableColumn fx:id="montantPayeCol" text="Paid (TND)" prefWidth="120"/>
            <TableColumn fx:id="resteCol" text="Balance (TND)" prefWidth="120"/>
            <TableColumn fx:id="modePaiementCol" text="Mode" prefWidth="120"/>
            <TableColumn fx:id="statutCol" text="Status" prefWidth="120"/>
        </columns>
    </TableView>
</VBox>


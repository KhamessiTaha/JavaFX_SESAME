<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.tahakhamessi.controller.StatisticsController" spacing="20" style="-fx-padding: 20">
    <Label text="Administrator Dashboard" styleClass="label-header"/>

    <HBox spacing="10">
        <Button text="Generate Report" onAction="#handleGenerateStatisticsReport" styleClass="button-primary"/>
    </HBox>

    <GridPane hgap="20" vgap="20">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="150" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="150" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="150" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="150" />
        </columnConstraints>

        <VBox styleClass="card" alignment="CENTER" spacing="10" GridPane.columnIndex="0" maxWidth="Infinity">
            <Label text="Total Reservations" styleClass="label-subheader" style="-fx-font-size: 14;"/>
            <Label fx:id="totalReservationsLabel" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
        </VBox>

        <VBox styleClass="card" alignment="CENTER" spacing="10" GridPane.columnIndex="1" maxWidth="Infinity">
            <Label text="Total Revenue" styleClass="label-subheader" style="-fx-font-size: 14;"/>
            <Label fx:id="totalRevenueLabel" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
        </VBox>

        <VBox styleClass="card" alignment="CENTER" spacing="10" GridPane.columnIndex="2" maxWidth="Infinity">
            <Label text="Fleet Availability" styleClass="label-subheader" style="-fx-font-size: 14;"/>
            <Label fx:id="availableVehiclesLabel" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
        </VBox>

        <VBox styleClass="card" alignment="CENTER" spacing="10" GridPane.columnIndex="3" maxWidth="Infinity">
            <Label text="Top Vehicle" styleClass="label-subheader" style="-fx-font-size: 14;"/>
            <Label fx:id="mostRentedLabel" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #9C27B0;" wrapText="true" alignment="CENTER"/>
        </VBox>
    </GridPane>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="15">
            <Label text="Vehicle Status Distribution" styleClass="label-subheader"/>
            <PieChart fx:id="statusChart" legendSide="BOTTOM" labelsVisible="true" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="15">
            <Label text="Recent Reservations" styleClass="label-subheader"/>
            <TableView fx:id="recentTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="recentClientCol" text="Client" prefWidth="120"/>
                    <TableColumn fx:id="recentVehicleCol" text="Vehicle" prefWidth="120"/>
                    <TableColumn fx:id="recentDateCol" text="Start Date" prefWidth="100"/>
                    <TableColumn fx:id="recentStatusCol" text="Status" prefWidth="90"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>
</VBox>


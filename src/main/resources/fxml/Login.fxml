<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.tahakhamessi.controller.LoginController" alignment="CENTER" spacing="25" styleClass="root">
    <stylesheets>
        <URL value="@/style/style.css" />
    </stylesheets>

    <VBox alignment="CENTER" spacing="20" styleClass="card" maxWidth="400">
        <Label text="Car Rental System" styleClass="label-header"/>

        <GridPane hgap="10" vgap="15" alignment="CENTER">
            <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="usernameField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200" promptText="Enter username"/>

            <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <PasswordField fx:id="passwordField" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="200" promptText="Enter password"/>
        </GridPane>

        <Label fx:id="errorLabel" style="-fx-text-fill: #F44336;"/>

        <Button text="Login" onAction="#handleLogin" styleClass="button-primary" prefWidth="200"/>

        <HBox alignment="CENTER" spacing="10">
            <Label text="Don't have an account?" style="-fx-font-size: 12;"/>
            <Hyperlink text="Register here" onAction="#handleRegister" style="-fx-font-size: 12;"/>
        </HBox>
    </VBox>
</VBox>


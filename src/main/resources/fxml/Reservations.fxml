<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.tahakhamessi.controller.ReservationsController" spacing="20" style="-fx-padding: 20">
    <Label text="Reservation Management" styleClass="label-header"/>

    <VBox fx:id="formSection" spacing="10" styleClass="card">
        <Label text="Reservation Details" styleClass="label-subheader"/>
        <GridPane hgap="15" vgap="10">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100" />
            </columnConstraints>

            <ComboBox fx:id="clientCombo" promptText="Select Client" GridPane.columnIndex="0" GridPane.rowIndex="0" maxWidth="Infinity"/>
            <ComboBox fx:id="vehiculeCombo" promptText="Select Vehicle" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity"/>
            <DatePicker fx:id="dateDebut" promptText="Start Date" GridPane.columnIndex="2" GridPane.rowIndex="0" maxWidth="Infinity"/>
            <DatePicker fx:id="dateFin" promptText="End Date" onAction="#handleCalculateDays" GridPane.columnIndex="3" GridPane.rowIndex="0" maxWidth="Infinity"/>

            <TextField fx:id="optionsField" promptText="Options (e.g. GPS)" GridPane.columnIndex="0" GridPane.rowIndex="1" maxWidth="Infinity"/>
            <TextField fx:id="prixOptionsField" promptText="Options Price (TND)" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity"/>
            <ComboBox fx:id="statutCombo" promptText="Status" GridPane.columnIndex="2" GridPane.rowIndex="1" maxWidth="Infinity"/>
        </GridPane>

        <HBox spacing="20" alignment="CENTER_LEFT">
            <HBox spacing="10">
                <Button fx:id="btnAdd" text="Add Reservation" onAction="#handleAddReservation" styleClass="button-success"/>
                <Button fx:id="btnUpdate" text="Update Selected" onAction="#handleUpdateReservation" styleClass="button-primary"/>
                <Button fx:id="btnDelete" text="Delete Selected" onAction="#handleDeleteReservation" styleClass="button-danger"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="prixTotalLabel" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
        </HBox>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search reservations..." HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button text="Search" onAction="#handleSearch" styleClass="button-primary"/>
        <Button text="Generate Contract" onAction="#handleGenerateContract" styleClass="button-primary"/>
        <Button text="Export to PDF" onAction="#handleExportReservations" styleClass="button-primary"/>
    </HBox>

    <Label fx:id="errorLabel" style="-fx-text-fill: #F44336;"/>
    <Label fx:id="successLabel" style="-fx-text-fill: #4CAF50;"/>

    <TableView fx:id="reservationTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol" text="ID" prefWidth="40"/>
            <TableColumn fx:id="clientNomCol" text="Client" prefWidth="150"/>
            <TableColumn fx:id="vehiculeNomCol" text="Vehicle" prefWidth="150"/>
            <TableColumn fx:id="dateDebCol" text="Start Date" prefWidth="100"/>
            <TableColumn fx:id="dateFinCol" text="End Date" prefWidth="100"/>
            <TableColumn fx:id="joursCol" text="Days" prefWidth="50"/>
            <TableColumn fx:id="prixCol" text="Total Price (TND)" prefWidth="120"/>
            <TableColumn fx:id="statutCol" text="Status" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>

